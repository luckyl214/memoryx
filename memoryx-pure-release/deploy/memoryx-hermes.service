[Unit]
Description=Mnemosyne-X Memory REST Service
After=network.target

[Service]
Type=simple
User=%i
WorkingDirectory=%h/memoryx
Environment=MEMORYX_ENV_FILE=%h/memoryx/.env
ExecStart=%h/memoryx/.venv/bin/uvicorn memoryx.api.rest_app:app --host 0.0.0.0 --port 8080
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
